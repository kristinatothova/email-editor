    }

    function exportMail() {
        const temp = document.createElement('div');
        temp.innerHTML = editor.innerHTML;
        temp.querySelectorAll('*').forEach(el => {
            if (el.tagName !== 'A') { el.style.fontFamily = 'Arial, sans-serif'; el.style.fontSize = '13pt'; }
        });
        navigator.clipboard.writeText(temp.innerHTML).then(() => alert("Exportovanรฉ a skopรญrovanรฉ!"));
    }

    function openHtmlModal() { document.getElementById('html-import-area').value = ""; document.getElementById('html-modal').style.display = 'flex'; }
    function closeHtmlModal() { document.getElementById('html-modal').style.display = 'none'; }
    function applyHtml() {
        editor.innerHTML = document.getElementById('html-import-area').value.trim();
        applyGlobalStyles(editor);
        updateCode();
        closeHtmlModal();
    }
    function showToast() {
        const t = document.getElementById('paste-toast');
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 2000);
    }

    init();
</script>
</body>
</html>
