<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <title>LABA / SKVOT Email Editor - FINAL STABLE</title>
    <style>
        :root { --bg: #1e1e1e; --panel: #2d2d2d; --accent: #4ade80; --text: #d4d4d4; }
        body { margin: 0; font-family: Arial, sans-serif; display: flex; height: 100vh; background: var(--bg); color: var(--text); overflow: hidden; }
        #sidebar { width: 280px; background: var(--panel); border-right: 1px solid #444; display: flex; flex-direction: column; }
        .sidebar-header { padding: 15px; background: #333; font-weight: bold; border-bottom: 1px solid #444; text-align: center; }
        .template-list { flex: 1; overflow-y: auto; padding: 10px; }
        .template-item { padding: 10px; background: #3d3d3d; margin-bottom: 5px; border-radius: 4px; cursor: pointer; font-size: 12px; }
        .template-item.active { background: #325244; border-left: 4px solid var(--accent); }
        #main-view { flex: 1; display: flex; flex-direction: column; position: relative; }
        .toolbar { padding: 10px; background: #333; border-bottom: 1px solid #444; display: flex; gap: 8px; align-items: center; }
        #visual-container { flex: 1; background-color: #F0F2F5; overflow-y: auto; padding: 20px; display: flex; justify-content: center; }
        #editor-surface { width: 600px; min-height: 800px; background: white; outline: none; color: #000; }
        #url-tooltip { position: fixed; background: rgba(0,0,0,0.9); color: white; padding: 5px 10px; border-radius: 4px; font-size: 11px; display: none; z-index: 9999; }
        .btn-tool { background: #444; color: white; border: none; padding: 8px 14px; border-radius: 4px; cursor: pointer; font-size: 11px; font-weight: bold; text-transform: uppercase; }
        .btn-export { background: var(--accent); color: #000; }
        #code-container { width: 350px; background: var(--panel); border-left: 1px solid #444; display: flex; flex-direction: column; }
        textarea { flex: 1; background: #161616; color: #85d7ff; padding: 10px; font-family: monospace; font-size: 10px; border: none; }
    </style>
</head>
<body>
<div id="url-tooltip"></div>
<div id="sidebar">
    <div class="sidebar-header">ŠABLÓNY (ARIAL)</div>
    <div id="tpl-list" class="template-list"></div>
</div>
<div id="main-view">
    <div class="toolbar">
        <button class="btn-tool" onclick="exec('bold')">B</button>
        <button class="btn-tool" onclick="exec('underline')">U</button>
        <button class="btn-tool" onclick="addLink()">🔗 LINK</button>
        <button class="btn-tool btn-export" onclick="exportMail()">🚀 EXPORTOVAŤ KÓD</button>
    </div>
    <div id="visual-container">
        <div id="editor-surface" contenteditable="true"></div>
    </div>
</div>
<div id="code-container"><textarea id="html-output" readonly></textarea></div>

<script>
    const editor = document.getElementById('editor-surface');
    const output = document.getElementById('html-output');
    const tooltip = document.getElementById('url-tooltip');

    // Tvoja pôvodná štruktúra s vymeneným logom a Arialom
    const TPL_WELCOME = `
    <div dir="ltr" style="background-color:#F6F6F6; font-family: Arial, sans-serif;">
        <table cellpadding="0" cellspacing="0" width="100%" style="background-color:#F6F6F6">
            <tr>
                <td align="center">
                    <table width="600" cellpadding="0" cellspacing="0" style="background-color:#efefef;">
                        <tr>
                            <td bgcolor="#000000" style="padding:10px 20px;">
                                <table width="100%" cellpadding="0" cellspacing="0">
                                    <tr>
                                        <td width="60" align="left">
                                            <img src="https://ekbdp.stripocdn.email/content/guids/CABINET_d57212fd479c0debee88e429cfb3654362f20cfc24d1f7de496921d97489495d/images/mask_group_3.png" width="47" height="47" style="display:block;">
                                        </td>
                                        <td align="right">
                                            <table cellpadding="0" cellspacing="0" bgcolor="#ffeb3b" style="border-radius:6px; width:400px;">
                                                <tr>
                                                    <td style="padding:15px; font-family:Arial, sans-serif; font-size:16px; color:#000000; font-weight:bold;">
                                                        Důležité info ke kurzu „{{automation.product.title}}“
                                                    </td>
                                                </tr>
                                            </table>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td bgcolor="#ffffff" style="padding:20px; font-family:Arial, sans-serif; font-size:18px; line-height:1.5;">
                                <img src="https://ekbdp.stripocdn.email/content/guids/CABINET_d57212fd479c0debee88e429cfb3654362f20cfc24d1f7de496921d97489495d/images/mask_group_3.png" width="560" style="display:block; margin-bottom:20px; border-radius:10px;">
                                <strong>Ahoj! 👋</strong><br><br>
                                Vítej v kurzu {{automation.product.title}} s {{lecturer}}. Jsme rádi, že sis pro svůj rozvoj vybral*a právě nás.
                                <br><br>
                                📅 <strong>Kdy začínáme?</strong>... (atď)
                            </td>
                        </tr>
                        <tr>
                            <td bgcolor="#000000" style="padding:15px 20px;">
                                <table width="100%" style="color:#ffffff; font-family:Arial; font-size:11px;">
                                    <tr>
                                        <td>Zavolej nám:<br>+420 790 285 029</td>
                                        <td align="right">Technická podpora:<br>info@l-a-b-a.cz</td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </div>`;

    const TPLS = [{ name: "01. Welcome letter", html: TPL_WELCOME }];

    function init() {
        TPLS.forEach((t, i) => {
            const div = document.createElement('div');
            div.className = 'template-item';
            div.innerText = t.name;
            div.onclick = () => { 
                editor.innerHTML = t.html; 
                updateCode(); 
                document.querySelectorAll('.template-item').forEach(x => x.classList.remove('active'));
                div.classList.add('active');
            };
            document.getElementById('tpl-list').appendChild(div);
        });
    }

    editor.addEventListener('mousemove', (e) => {
        const target = e.target.closest('a');
        if (target) {
            tooltip.innerText = target.getAttribute('href');
            tooltip.style.display = 'block';
            tooltip.style.left = (e.clientX + 15) + 'px';
            tooltip.style.top = (e.clientY + 15) + 'px';
        } else { tooltip.style.display = 'none'; }
    });

    function exec(cmd) { document.execCommand(cmd, false, null); updateCode(); }
    function addLink() {
        const url = prompt("URL:");
        if (url) { 
            document.execCommand('createLink', false, url); 
            updateCode(); 
        }
    }
    function updateCode() { output.value = editor.innerHTML; }
    editor.addEventListener('input', updateCode);
    function exportMail() { navigator.clipboard.writeText(editor.innerHTML).then(() => alert("KÓD SKOPÍROVANÝ!")); }
    init();
</script>
</body>
</html>
