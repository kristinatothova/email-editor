                <button onclick="closeHtmlModal()" class="btn-tool">Zruลกiลฅ</button>
                <button onclick="applyHtml()" class="btn-tool" style="background:#6d28d9; padding:8px 20px; font-weight:bold;">โ POUลฝIลค A PREFORMAลคOVAลค</button>
            </div>
        </div>
    </div>
    
    <div id="visual-container">
        <div id="editor-surface" contenteditable="true" spellcheck="false"></div>
    </div>
