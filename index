    <style>
        :root { --bg: #1e1e1e; --panel: #2d2d2d; --accent: #4ade80; --text: #d4d4d4; }
        body { margin: 0; font-family: Arial, sans-serif; display: flex; height: 100vh; background: var(--bg); color: var(--text); overflow: hidden; }
        #sidebar { width: 280px; background: var(--panel); border-right: 1px solid #444; display: flex; flex-direction: column; }
        .sidebar-header { padding: 15px; background: #333; font-weight: bold; border-bottom: 1px solid #444; text-align: center; }
        .template-list { flex: 1; overflow-y: auto; padding: 10px; }
        .template-item { padding: 10px; background: #3d3d3d; margin-bottom: 5px; border-radius: 4px; cursor: pointer; font-size: 12px; }
        .template-item.active { background: #325244; border-left: 4px solid var(--accent); }
        #main-view { flex: 1; display: flex; flex-direction: column; position: relative; }
        .toolbar { padding: 10px; background: #333; border-bottom: 1px solid #444; display: flex; gap: 8px; align-items: center; }
        #visual-container { flex: 1; background-color: #F0F2F5; overflow-y: auto; padding: 20px; display: flex; justify-content: center; }
        #editor-surface { width: 600px; min-height: 800px; background: white; outline: none; color: #000; }
        #url-tooltip { position: fixed; background: rgba(0,0,0,0.9); color: white; padding: 5px 10px; border-radius: 4px; font-size: 11px; display: none; z-index: 9999; }
        .btn-tool { background: #444; color: white; border: none; padding: 8px 14px; border-radius: 4px; cursor: pointer; font-size: 11px; font-weight: bold; text-transform: uppercase; }
        .btn-export { background: var(--accent); color: #000; }
        #code-container { width: 350px; background: var(--panel); border-left: 1px solid #444; display: flex; flex-direction: column; }
        textarea { flex: 1; background: #161616; color: #85d7ff; padding: 10px; font-family: monospace; font-size: 10px; border: none; }
    </style>
</head>
<body>
<div id="url-tooltip"></div>
<div id="sidebar">
