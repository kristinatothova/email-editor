                if (parent && parent.tagName === 'A') {
                    parent.style.color = MY_BLUE;
                    parent.style.textDecoration = 'underline';
                    parent.style.fontFamily = 'Arial, sans-serif';
                    parent.style.fontSize = '13pt';
                }
            }
            updateCode(); 
        }
    }
    function cleanSelection() { document.execCommand('removeFormat', false, null); updateCode(); }
    function updateCode() { output.value = editor.innerHTML; }
