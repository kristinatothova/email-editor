<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <title>LABA / SKVOT Email Editor V2 - Unified Buttons</title>
    <style>
        :root { 
            --bg: #1e1e1e; 
            --panel: #2d2d2d; 
            --accent: #4ade80; 
            --text: #d4d4d4; 
            --link-blue: #1f5fcf; 
        }
        body { margin: 0; font-family: Arial, sans-serif; display: flex; height: 100vh; background: var(--bg); color: var(--text); overflow: hidden; }
        
        #sidebar { width: 280px; background: var(--panel); border-right: 1px solid #444; display: flex; flex-direction: column; }
        .sidebar-header { padding: 15px; background: #333; font-weight: bold; border-bottom: 1px solid #444; text-align: center; }
        .template-list { flex: 1; overflow-y: auto; padding: 10px; }
        .template-item { padding: 10px; background: #3d3d3d; margin-bottom: 5px; border-radius: 4px; cursor: pointer; font-size: 12px; transition: 0.2s; }
        .template-item:hover { background: #4d4d4d; }
        .template-item.active { background: #325244; border-left: 4px solid var(--accent); }

        #main-view { flex: 1; display: flex; flex-direction: column; position: relative; }
        .toolbar { padding: 10px; background: #333; border-bottom: 1px solid #444; display: flex; gap: 8px; align-items: center; }
        
        #visual-container { flex: 1; background-color: #F0F2F5; overflow-y: auto; padding: 20px; display: flex; justify-content: center; align-items: flex-start; }
        
        #editor-surface { 
            width: 600px; 
            min-height: 800px; 
            background: white; 
            box-shadow: 0 5px 20px rgba(0,0,0,0.1); 
            outline: none; 
            color: #000; 
            padding: 0 !important; 
            margin: 0 auto; 
            font-family: Arial, sans-serif;
            line-height: 1.5; 
        }
        
        #editor-surface a { color: var(--link-blue) !important; text-decoration: underline; }

        #code-container { width: 350px; background: var(--panel); border-left: 1px solid #444; display: flex; flex-direction: column; }
        textarea { flex: 1; background: #161616; color: #85d7ff; padding: 10px; font-family: monospace; font-size: 10px; border: none; resize: none; }

        /* ZJEDNOTENÉ TLAČIDLÁ - Všetky Bold a Arial */
        .btn-tool { 
            background: #444; 
            color: white; 
            border: none; 
            padding: 8px 14px; 
            border-radius: 4px; 
            cursor: pointer; 
            font-size: 12px; 
            font-family: Arial, sans-serif; 
            font-weight: bold; /* Všetky budú tučné */
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .btn-export { background: var(--accent); color: #000; text-transform: uppercase; }
        .btn-clean { background: #f59e0b; color: #000; }
        .btn-import { background: #6d28d9; }
        
        .btn-tool:hover { filter: brightness(1.1); }
    </style>
</head>
<body>

<div id="sidebar">
    <div class="sidebar-header">ŠABLÓNY (ARIAL)</div>
    <div id="tpl-list" class="template-list"></div>
</div>

<div id="main-view">
    <div class="toolbar">
        <button class="btn-tool" onclick="exec('bold')">B</button>
        <button class="btn-tool" onclick="exec('underline')">U</button>
        <button class="btn-tool" onclick="addLink()">🔗 Link</button>
        <div style="width:1px; height:20px; background:#555; margin:0 5px;"></div>
        <button class="btn-tool btn-clean" onclick="cleanSelection()">🧹 Clear saver</button>
        <div style="width:1px; height:20px; background:#555; margin:0 5px;"></div>
        <button class="btn-tool btn-export" onclick="exportMail()">🚀 EXPORTOVAŤ KÓD</button>
        <button class="btn-tool btn-import" onclick="openHtmlModal()">⬆ Vložiť HTML</button>
    </div>

    <div id="html-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:1000; align-items:center; justify-content:center;">
        <div style="background:#2d2d2d; border:1px solid #555; border-radius:8px; width:800px; max-width:95vw; display:flex; flex-direction:column;">
            <div style="padding:15px; background:#252525; color:white; font-weight:bold;">Vložiť zdrojový kód</div>
            <textarea id="html-import-area" style="height:450px; background:#161616; color:#85d7ff; padding:15px; font-family:monospace; border:none; outline:none;"></textarea>
            <div style="padding:15px; background:#252525; display:flex; gap:10px; justify-content:flex-end;">
                <button onclick="applyHtml()" class="btn-tool btn-import">✅ POUŽIŤ</button>
            </div>
        </div>
    </div>

    <div id="visual-container">
        <div id="editor-surface" contenteditable="true" spellcheck="false"></div>
    </div>
</div>

<div id="code-container">
    <textarea id="html-output" readonly></textarea>
</div>

<script>
    const editor = document.getElementById('editor-surface');
    const output = document.getElementById('html-output');
    document.execCommand('defaultParagraphSeparator', false, 'div');

    const FOOTER_HTML = `
        <table cellpadding="0" cellspacing="0" width="100%" style="background-color:#000000; color:#ffffff; font-family:Arial, sans-serif; font-size:11px;">
            <tbody>
                <tr><td style="padding:15px 20px;">Zavolej nám:<br>+420 790 285 029</td><td align="right" style="padding:15px 20px;">Technická podpora:<br>info@l-a-b-a.cz</td></tr>
            </tbody>
        </table>
        <div class="footer-copyright" style="background-color:#eeeeee; color:#333333; font-family:Arial, sans-serif; font-size:11px; padding:15px 20px; text-align:center; line-height:16.5px;">
            Copyright©️ 2026, Laba Czech vzdělávání s.r.o. All Rights Reserved.<br>{{address}}<br>
            Tuto provozní zprávu jste obdrželi, protože jste naším zákazníkem. Nejedná se o marketingové sdělení.
        </div>`;

    const HEADER_FIX = `
        <table cellpadding="0" cellspacing="0" width="100%" style="background-color:#000000; margin:0; padding:0;">
            <tbody>
                <tr>
                    <td align="center" style="padding:20px 20px;">
                        <img src="https://ekbdp.stripocdn.email/content/guids/CABINET_d57212fd479c0debee88e429cfb3654362f20cfc24d1f7de496921d97489495d/images/mask_group_3.png" width="47" height="47" style="display:inline-block; vertical-align:middle;">
                        <div style="display:inline-block; background:#ffeb3b; padding:10px 15px; margin-left:20px; border-radius:6px; font-weight:bold; color:black; font-size:12pt; vertical-align:middle; font-family:Arial, sans-serif; text-align:left; width:400px; max-width:100%; line-height:1.3;">Důležité info ke kurzu {{automation.product.title}}</div>
                    </td>
                </tr>
            </tbody>
        </table>`;

    const TPLS = [
        { name: "01. Welcome letter", html: `<table cellpadding="0" cellspacing="0" width="100%" style="background-color:#ffffff; margin:0; padding:0;"><tbody><tr><td align="center"><table cellpadding="0" cellspacing="0" width="600" style="background-color:#ffffff;"><tbody><tr><td>${HEADER_FIX}</td></tr><tr><td style="padding:20px; color:#000000; font-family:Arial, sans-serif; font-size:13pt; line-height:1.5;"><strong>Ahoj! 👋</strong><br><br>Vítej v kurzu. Jsme rádi, že jsi tu.</td></tr><tr><td>${FOOTER_HTML}</td></tr></tbody></table></td></tr></tbody></table>` },
        { name: "02. Day before", html: `<table cellpadding="0" cellspacing="0" width="100%" style="background-color:#ffffff; margin:0; padding:0;"><tbody><tr><td align="center"><table cellpadding="0" cellspacing="0" width="600" style="background-color:#ffffff;"><tbody><tr><td>${HEADER_FIX}</td></tr><tr><td style="padding:20px; color:#000000; font-family:Arial, sans-serif; font-size:13pt; line-height:1.5;">Tu vložte text pre Day before...</td></tr><tr><td>${FOOTER_HTML}</td></tr></tbody></table></td></tr></tbody></table>` },
        { name: "03. Certifikát o účasti", html: `<table cellpadding="0" cellspacing="0" width="100%" style="background-color:#ffffff; margin:0; padding:0;"><tbody><tr><td align="center"><table cellpadding="0" cellspacing="0" width="600" style="background-color:#ffffff;"><tbody><tr><td>${HEADER_FIX}</td></tr><tr><td style="padding:20px; color:#000000; font-family:Arial, sans-serif; font-size:13pt; line-height:1.5;">Tu vložte text pre Certifikát o účasti...</td></tr><tr><td>${FOOTER_HTML}</td></tr></tbody></table></td></tr></tbody></table>` },
        { name: "04. Certifikát o úspechu", html: `<table cellpadding="0" cellspacing="0" width="100%" style="background-color:#ffffff; margin:0; padding:0;"><tbody><tr><td align="center"><table cellpadding="0" cellspacing="0" width="600" style="background-color:#ffffff;"><tbody><tr><td>${HEADER_FIX}</td></tr><tr><td style="padding:20px; color:#000000; font-family:Arial, sans-serif; font-size:13pt; line-height:1.5;">Tu vložte text pre Certifikát o úspechu...</td></tr><tr><td>${FOOTER_HTML}</td></tr></tbody></table></td></tr></tbody></table>` },
        { name: "05. Info mail", html: `<table cellpadding="0" cellspacing="0" width="100%" style="background-color:#ffffff; margin:0; padding:0;"><tbody><tr><td align="center"><table cellpadding="0" cellspacing="0" width="600" style="background-color:#ffffff;"><tbody><tr><td>${HEADER_FIX}</td></tr><tr><td style="padding:20px; color:#000000; font-family:Arial, sans-serif; font-size:13pt; line-height:1.5;">Tu vložte text pre Info mail...</td></tr><tr><td>${FOOTER_HTML}</td></tr></tbody></table></td></tr></tbody></table>` },
        { name: "06. Pauza v kurzu", html: `<table cellpadding="0" cellspacing="0" width="100%" style="background-color:#ffffff; margin:0; padding:0;"><tbody><tr><td align="center"><table cellpadding="0" cellspacing="0" width="600" style="background-color:#ffffff;"><tbody><tr><td>${HEADER_FIX}</td></tr><tr><td style="padding:20px; color:#000000; font-family:Arial, sans-serif; font-size:13pt; line-height:1.5;">Tu vložte text pre Pauza v kurzu...</td></tr><tr><td>${FOOTER_HTML}</td></tr></tbody></table></td></tr></tbody></table>` }
    ];

    function init() {
        TPLS.forEach((t, i) => {
            const div = document.createElement('div');
            div.className = 'template-item';
            div.innerText = t.name;
            div.onclick = () => { 
                editor.innerHTML = t.html; 
                applyStyles(editor); 
                updateCode(); 
                document.querySelectorAll('.template-item').forEach(x => x.classList.remove('active'));
                div.classList.add('active');
            };
            document.getElementById('tpl-list').appendChild(div);
        });
    }

    function applyStyles(parent) {
        parent.querySelectorAll('*').forEach(node => {
            node.setAttribute('contenteditable', 'true');
            const isSmall = node.style.fontSize === '11px' || node.classList.contains('footer-copyright') || node.closest('.footer-copyright');
            if (!isSmall && node.tagName !== 'A' && node.tagName !== 'IMG') {
                node.style.fontFamily = 'Arial, sans-serif';
                if (!node.style.fontSize) node.style.fontSize = '13pt';
            }
        });
    }

    function exec(cmd) { document.execCommand(cmd, false, null); updateCode(); }
    function addLink() {
        const url = prompt("URL:");
        if (url) { 
            document.execCommand('createLink', false, url); 
            const sel = window.getSelection();
            let a = sel.anchorNode.parentElement;
            if (a.tagName !== 'A') a = a.closest('a');
            if (a) { a.style.color = '#1f5fcf'; a.style.textDecoration = 'underline'; }
            updateCode(); 
        }
    }
    function cleanSelection() { document.execCommand('removeFormat', false, null); updateCode(); }
    function updateCode() { output.value = editor.innerHTML; }
    editor.addEventListener('input', updateCode);
    function exportMail() { navigator.clipboard.writeText(editor.innerHTML).then(() => alert("Kód skopírovaný!")); }
    function openHtmlModal() { document.getElementById('html-import-area').value = ''; document.getElementById('html-modal').style.display = 'flex'; }
    function applyHtml() {
        editor.innerHTML = document.getElementById('html-import-area').value;
        applyStyles(editor);
        updateCode();
        document.getElementById('html-modal').style.display = 'none';
    }
    init();
</script>
</body>
</html>
