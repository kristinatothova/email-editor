<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <title>LABA / SKVOT Email Editor - FINAL STABLE</title>
    <style>
        :root { 
            --bg: #1e1e1e; 
            --panel: #2d2d2d; 
            --accent: #4ade80; 
            --text: #d4d4d4; 
            --link-blue: #1f5fcf; 
        }
        body { margin: 0; font-family: Arial, sans-serif; display: flex; height: 100vh; background: var(--bg); color: var(--text); overflow: hidden; }
        
        #sidebar { width: 280px; background: var(--panel); border-right: 1px solid #444; display: flex; flex-direction: column; }
        .sidebar-header { padding: 15px; background: #333; font-weight: bold; border-bottom: 1px solid #444; text-align: center; }
        .template-list { flex: 1; overflow-y: auto; padding: 10px; }
        .template-item { padding: 10px; background: #3d3d3d; margin-bottom: 5px; border-radius: 4px; cursor: pointer; font-size: 12px; transition: 0.2s; }
        .template-item:hover { background: #4d4d4d; }
        .template-item.active { background: #325244; border-left: 4px solid var(--accent); }

        #main-view { flex: 1; display: flex; flex-direction: column; position: relative; }
        .toolbar { padding: 10px; background: #333; border-bottom: 1px solid #444; display: flex; gap: 8px; align-items: center; }
        
        #visual-container { flex: 1; background-color: #F0F2F5; overflow-y: auto; padding: 20px; display: flex; justify-content: center; align-items: flex-start; }
        
        #editor-surface { 
            width: 600px; 
            min-height: 800px; 
            background: white; 
            box-shadow: 0 5px 20px rgba(0,0,0,0.1); 
            outline: none; 
            color: #000; 
            padding: 0 !important; 
            margin: 0 auto; 
            font-family: Arial, sans-serif;
            line-height: 1.5; 
        }
        
        /* Tooltip pre URL náhľad */
        #url-tooltip {
            position: fixed;
            background: rgba(0,0,0,0.9);
            color: white;
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 11px;
            pointer-events: none;
            display: none;
            z-index: 9999;
            white-space: nowrap;
            border: 1px solid #555;
        }

        /* JEDNOTNÉ TLAČIDLÁ - BOLD + UPPERCASE */
        .btn-tool { 
            background: #444; 
            color: white; 
            border: none; 
            padding: 8px 14px; 
            border-radius: 4px; 
            cursor: pointer; 
            font-size: 11px; 
            font-family: Arial, sans-serif; 
            font-weight: bold; 
            text-transform: uppercase; 
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .btn-export { background: var(--accent); color: #000; }
        .btn-clean { background: #f59e0b; color: #000; }
        .btn-import { background: #6d28d9; }
        .btn-tool:hover { filter: brightness(1.1); }

        #code-container { width: 350px; background: var(--panel); border-left: 1px solid #444; display: flex; flex-direction: column; }
        textarea { flex: 1; background: #161616; color: #85d7ff; padding: 10px; font-family: monospace; font-size: 10px; border: none; resize: none; }
    </style>
</head>
<body>

<div id="url-tooltip"></div>

<div id="sidebar">
    <div class="sidebar-header">ŠABLÓNY (ARIAL)</div>
    <div id="tpl-list" class="template-list"></div>
</div>

<div id="main-view">
    <div class="toolbar">
        <button class="btn-tool" onclick="exec('bold')">B</button>
        <button class="btn-tool" onclick="exec('underline')">U</button>
        <button class="btn-tool" onclick="addLink()">🔗 LINK</button>
        <div style="width:1px; height:20px; background:#555; margin:0 5px;"></div>
        <button class="btn-tool btn-clean" onclick="cleanSelection()">🧹 CLEAR SAVER</button>
        <div style="width:1px; height:20px; background:#555; margin:0 5px;"></div>
        <button class="btn-tool btn-export" onclick="exportMail()">🚀 EXPORTOVAŤ KÓD</button>
        <button class="btn-tool btn-import" onclick="openHtmlModal()">⬆ VLOŽIŤ HTML</button>
    </div>

    <div id="html-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:1000; align-items:center; justify-content:center;">
        <div style="background:#2d2d2d; border:1px solid #555; border-radius:8px; width:800px; max-width:95vw; display:flex; flex-direction:column;">
            <div style="padding:15px; background:#252525; color:white; font-weight:bold;">VLOŽIŤ ZDROJOVÝ KÓD</div>
            <textarea id="html-import-area" style="height:450px; background:#161616; color:#85d7ff; padding:15px; font-family:monospace; border:none; outline:none;"></textarea>
            <div style="padding:15px; background:#252525; display:flex; gap:10px; justify-content:flex-end;">
                <button onclick="applyHtml()" class="btn-tool btn-import">✅ POUŽIŤ</button>
            </div>
        </div>
    </div>

    <div id="visual-container">
        <div id="editor-surface" contenteditable="true" spellcheck="false"></div>
    </div>
</div>

<div id="code-container">
    <textarea id="html-output" readonly></textarea>
</div>

