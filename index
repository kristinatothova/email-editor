    // Link Preview logic
    editor.addEventListener('mouseover', (e) => {
        const target = e.target.closest('a');
        if (target) { preview.innerText = target.getAttribute('href') || 'No URL'; preview.style.display = 'block'; }
    });
    editor.addEventListener('mousemove', (e) => {
